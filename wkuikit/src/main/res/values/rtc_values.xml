<resources>
    <style name="RtcCallTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="RtcCircleButton">
        <item name="android:layout_width">82dp</item>
        <item name="android:layout_height">82dp</item>
        <item name="android:layout_marginLeft">7dp</item>
        <item name="android:layout_marginRight">7dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#F2FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lines">1</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">7dp</item>
    </style>

    <style name="RtcSideButton">
        <item name="android:layout_width">54dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#F2FFFFFF</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lines">1</item>
        <item name="android:paddingTop">7dp</item>
        <item name="android:paddingBottom">5dp</item>
    </style>
</resources>
