<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rtcRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <View
        android:id="@+id/gradientShade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000" />

    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="58dp"
        android:paddingRight="24dp">

        <FrameLayout
            android:layout_width="108dp"
            android:layout_height="108dp">

            <ImageView
                android:id="@+id/avatarImage"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/avatarText"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:gravity="center"
                android:text="友"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/nameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="好友"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="连接中…"
            android:textColor="#D6FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/localContainer"
        android:layout_width="112dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="96dp"
        android:layout_marginEnd="14dp"
        android:elevation="12dp"
        android:visibility="gone">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/localRenderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/sideControlsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:id="@+id/controlsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp">

            <LinearLayout
                android:id="@+id/controlsRowTop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/micBtn"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lines="1"
                    android:paddingTop="3dp"
                    android:paddingBottom="1dp"
                    android:textColor="#EEFFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/speakerBtn"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lines="1"
                    android:paddingTop="3dp"
                    android:paddingBottom="1dp"
                    android:textColor="#EEFFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/camBtn"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lines="1"
                    android:paddingTop="3dp"
                    android:paddingBottom="1dp"
                    android:textColor="#EEFFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/controlsRowBottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="0.5" />

                <TextView
                    android:id="@+id/flipBtn"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lines="1"
                    android:paddingTop="3dp"
                    android:paddingBottom="1dp"
                    android:textColor="#EEFFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/endBtn"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:lines="1"
                    android:paddingTop="3dp"
                    android:paddingBottom="1dp"
                    android:textColor="#FFFF4B55"
                    android:textSize="10sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="0.5" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/incomingLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="56dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/rejectBtn"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginRight="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/rtc_reject"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/acceptBtn"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/rtc_accept"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
