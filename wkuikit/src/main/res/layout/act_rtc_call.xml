<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rtcRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070B12">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <View
        android:id="@+id/gradientShade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000" />

    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="58dp"
        android:paddingRight="24dp">

        <TextView
            android:id="@+id/avatarText"
            android:layout_width="106dp"
            android:layout_height="106dp"
            android:gravity="center"
            android:text="@string/rtc_friend_initial"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/rtc_friend"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/rtc_connecting"
            android:textColor="#D6FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/localContainer"
        android:layout_width="112dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="96dp"
        android:layout_marginEnd="14dp"
        android:elevation="12dp"
        android:padding="2dp"
        android:visibility="gone">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/localRenderer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/sideToolsLayout"
        android:layout_width="62dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="10dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView android:id="@+id/camBtn" style="@style/RtcSideButton" />
        <TextView android:id="@+id/flipBtn" style="@style/RtcSideButton" />
        <TextView android:id="@+id/qualityBtn" style="@style/RtcSideButton" />
        <TextView android:id="@+id/beautyBtn" style="@style/RtcSideButton" />
        <TextView android:id="@+id/shareBtn" style="@style/RtcSideButton" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:id="@+id/controlsCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp">

            <TextView android:id="@+id/micBtn" style="@style/RtcCircleButton" />
            <TextView android:id="@+id/speakerBtn" style="@style/RtcCircleButton" />
            <TextView android:id="@+id/endBtn" style="@style/RtcCircleButton" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/incomingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="22dp"
        android:paddingRight="22dp"
        android:paddingBottom="58dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/rejectBtn"
                android:layout_width="132dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="@string/rtc_reject"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="18dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/acceptBtn"
                android:layout_width="132dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="@string/rtc_accept"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
